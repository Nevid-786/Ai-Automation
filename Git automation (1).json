      "parameters": {
        "jsCode": "// Extract only the Notable Projects section\nconst readme = $json.data;\n\nconst start = readme.indexOf('### 🚀 Notable Projects');\nconst end = readme.indexOf('### 🔄 Current Goals');\n\nif (start !== -1 && end !== -1) {\n  return [{\n    notableProjects: readme.slice(start, end).trim()\n  }];\n} else {\n  return [{\n    notableProjects: 'Section not found'\n  }];\n}\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        736
      ],
      "id": "60072ab7-f5e3-4ea0-9074-00df80cc3508",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "// ✅ Extract the old README safely\nlet oldReadme =\n  $json.data ||\n  $json.readme ||\n  ($json.output && ($json.output.data || $json.output.readme)) ||\n  \"\";\n\nif (typeof oldReadme !== \"string\") {\n  oldReadme = JSON.stringify(oldReadme, null, 2);\n}\n\n// ✅ Extract the updated section (may be JSON or Markdown)\nlet updatedSection =\n  $json.updatedProjects ||\n  $json.data ||\n  ($json.output && ($json.output.updatedProjects || $json.output.data)) ||\n  \"\";\n\n// 🧹 STEP 1 — Remove code fences like ```json or ```markdown\nupdatedSection = updatedSection\n  .replace(/```json|```markdown|```/gi, \"\")\n  .trim();\n\n// 🧹 STEP 2 — Try to parse JSON and extract .data if it exists\nif (typeof updatedSection === \"string\" && updatedSection.trim().startsWith(\"{\")) {\n  try {\n    const parsed = JSON.parse(updatedSection);\n    updatedSection = parsed.data || parsed.content || updatedSection;\n  } catch (e) {\n    // ignore if not valid JSON\n  }\n}\n\n// 🧹 STEP 3 — Remove leftover {\"data\": \"...\"} fragments if still present\nupdatedSection = updatedSection\n  .replace(/^\\s*\\{?\\s*\"data\"\\s*:\\s*\"?/i, \"\")\n  .replace(/\"\\s*\\}?$/, \"\")\n  .replace(/\\\\n/g, \"\\n\")\n  .replace(/\\\\\"/g, '\"')\n  .trim();\n\n// ✅ Replace inside README\nconst start = oldReadme.indexOf(\"### 🚀 Notable Projects\");\nconst end = oldReadme.indexOf(\"### 🔄 Current Goals\");\n\nlet newReadme;\nif (start !== -1 && end !== -1) {\n  newReadme =\n    oldReadme.slice(0, start) +\n    updatedSection.trim() +\n    \"\\n\\n\" +\n    oldReadme.slice(end);\n} else {\n  // append if section not found\n  newReadme = oldReadme + \"\\n\\n\" + updatedSection;\n}\n\n// ✅ Always return valid n8n item\nreturn [{ newReadme }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
