    {
      "parameters": {
        "jsCode": "// n8n Code node (JavaScript) - Run Once for All Items\n// This code finds the AI output string (handles multiple shapes), normalizes newlines,\n// extracts lines starting with '- ' or bullet chars, then converts them to a markdown table.\n\nconst item = items && items.length ? items[0].json : {};\n\n// Try several common places where the AI output might be\nlet aiOutput =\n  // direct common keys\n  item.data ||\n  item.text ||\n  item.output ||\n  // sometimes nested\n  (item.output && (item.output.data || item.output.text)) ||\n  // sometimes ai outputs array\n  (Array.isArray(item.output) && item.output[0] && (item.output[0].data || item.output[0].text)) ||\n  // fallback: stringified JSON (if the node returned a pure JSON object)\n  null;\n\n// If not found yet, try to find first non-empty string value in object\nif (!aiOutput) {\n  for (const k of Object.keys(item)) {\n    const v = item[k];\n    if (typeof v === 'string' && v.trim().length > 0) {\n      aiOutput = v;\n      break;\n    }\n  }\n}\n\n// Final fallback: stringify the whole JSON if nothing else found\nif (!aiOutput) aiOutput = JSON.stringify(item, null, 2);\n\n// If aiOutput is not a string (object), stringify it\nif (typeof aiOutput !== 'string') {\n  aiOutput = JSON.stringify(aiOutput);\n}\n\n// Convert escaped newline sequences like \"\\n\" into actual newlines\n// (handles double-escaped strings as well)\naiOutput = aiOutput.replace(/\\\\n/g, '\\n').replace(/\\\\r/g, '\\r');\n\n// Normalize CRLF -> LF\naiOutput = aiOutput.replace(/\\r\\n/g, '\\n');\n\n// Split into lines\nconst allLines = aiOutput.split('\\n');\n\n// Pick lines that look like project bullets.\n// Accepts lines starting with '- ' or '•' or other common bullets.\nconst projectLines = allLines.filter(l => {\n  const t = l.trim();\n  return t.startsWith('- ') || t.startsWith('•') || /^\\-?\\s*🛒|^-\\s*🛒/.test(t);\n});\n\n// If none found, also try to detect lines that contain an emoji + name + dash\nif (projectLines.length === 0) {\n  for (const l of allLines) {\n    if (/–| - |—/.test(l) && /[A-Za-z0-9_\\-]/.test(l)) projectLines.push(l);\n  }\n}\n\n// Convert project lines into table rows\nconst rows = projectLines.map(line => {\n  // Remove leading bullet and trim\n  let raw = line.replace(/^\\s*[-•]\\s*/, '').trim();\n\n  // Sometimes projects are in the form: \"🛒 Amazone_clone – Description\"\n  // Split by en-dash/em-dash/hyphen surrounded by spaces\n  const parts = raw.split(/\\s+–\\s+|\\s+—\\s+|\\s+-\\s+/);\n\n  // If parts length < 2, try splitting only at first ' – ' char or ' - '\n  if (parts.length < 2) {\n    const idx = raw.indexOf('–') !== -1 ? raw.indexOf('–') : raw.indexOf('-');\n    if (idx !== -1) parts = [ raw.slice(0, idx).trim(), raw.slice(idx + 1).trim() ];\n  }\n\n  // Fallback: if still 1 part, put whole text in project column and blank description\n  const project = (parts[0] || '').trim();\n  const desc = (parts[1] || '').trim();\n\n  // Keep any markdown link or formatting inside project text (no change)\n  return `| ${project} | ${desc} |`;\n}).filter(Boolean);\n\n// Build table; if no rows found, return the original section unchanged\nlet table;\nif (rows.length === 0) {\n  // As fallback return the raw AI output but with newlines fixed\n  table = aiOutput;\n} else {\n  table = [\n    '### 🚀 Notable Projects',\n    '',\n    '| Project | Description |',\n    '|---|---|',\n    ...rows,\n    '',\n    '---',\n    ''\n  ].join('\\n');\n}\n\n// Return as updatedProjects\nreturn [{ updatedProjects: table }];\n"
      },
